<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.bankapp.controller.LoginController"
           styleClass="auth-root">

    <VBox alignment="CENTER" spacing="0" StackPane.alignment="CENTER">
        <HBox alignment="CENTER">
            <VBox styleClass="auth-card" spacing="20">

                <!-- Header -->
                <VBox spacing="6">
                    <Label text="🏦 NeoBank" styleClass="auth-title"/>
                    <Label text="Sign in to your account" styleClass="auth-subtitle"/>
                </VBox>

                <!-- Error Banner -->
                <Label fx:id="errorLabel" text="" styleClass="label-danger" wrapText="true"
                       managed="false" visible="false"/>

                <!-- Username -->
                <VBox spacing="6">
                    <Label text="Username" styleClass="label-muted"/>
                    <TextField fx:id="usernameField" promptText="Enter your username"/>
                    <Label fx:id="usernameError" text="" styleClass="label-danger" managed="false" visible="false"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="Password" styleClass="label-muted"/>
                    <StackPane fx:id="passwordStack">
                        <PasswordField fx:id="passwordField" promptText="Enter your password"/>
                        <TextField fx:id="passwordVisible" promptText="Enter your password"
                                   managed="false" visible="false"/>
                        <Button text="👁" onAction="#togglePassword"
                                style="-fx-background-color:transparent; -fx-cursor:hand; -fx-font-size:14px;"
                                StackPane.alignment="CENTER_RIGHT" translateX="-10"/>
                    </StackPane>
                    <Label fx:id="passwordError" text="" styleClass="label-danger" managed="false" visible="false"/>
                </VBox>

                <!-- Sign In Button -->
                <Button text="Sign In" onAction="#handleLogin"
                        styleClass="btn-primary" maxWidth="Infinity"/>

                <Separator/>

                <!-- Register link -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Don't have an account?" styleClass="label-muted"/>
                    <Label text="Create one" styleClass="link-label" onMouseClicked="#goToRegister"/>
                </HBox>

            </VBox>
        </HBox>
    </VBox>
</StackPane>
